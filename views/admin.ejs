<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PomoTick · Admin</title>
  <link rel="shortcut icon" href="/logo.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;0,400;0,500;1,300&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20,300,0,0" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<aside id="sidebar">
  <div class="sidebar-top">
    <div class="brand">
      <svg width="28" height="28" viewBox="0 0 31 32" fill="none"><path d="M13.003 20.6648C11.8363 20.6648 10.3338 19.8038 10.3338 18.6371V12.0545H2.20129C1.03028 12.0545 0 12.5582 0 13.7249V29.4388C0 30.6098 1.03028 31.8583 2.20129 31.8583H17.9152C19.0862 31.8583 19.8052 30.6098 19.8052 29.4388V20.6648H13.003Z" fill="currentColor"/><path d="M9.47275 9.2303C9.48688 9.507 9.39122 9.778 9.20659 9.984C9.02196 10.191 8.76329 10.316 8.48687 10.332H0.987254C0.710829 10.316 0.452166 10.191 0.267536 9.984C0.0829064 9.778 -0.0127533 9.507 0.0013679 9.2303V1.10212C-0.0127533 0.826 0.0829064 0.555 0.267536 0.348C0.452166 0.142 0.710829 0.017 0.987254 0H8.48687C8.76329 0.017 9.02196 0.142 9.20659 0.348C9.39122 0.555 9.48688 0.826 9.47275 1.10212V9.2303Z" fill="currentColor"/><path d="M30.9986 30.7562C31.0128 31.033 30.9171 31.304 30.7325 31.51C30.5478 31.717 30.2892 31.842 30.0127 31.858H22.5131C22.2367 31.842 21.978 31.717 21.7934 31.51C21.6088 31.304 21.5131 31.033 21.5272 30.7562V22.628C21.5131 22.351 21.6088 22.08 21.7934 21.874C21.978 21.668 22.2367 21.543 22.5131 21.526H30.0127C30.2892 21.543 30.5478 21.668 30.7325 21.874C30.9171 22.08 31.0128 22.351 30.9986 22.628V30.7562Z" fill="currentColor"/><path d="M28.8848 0H13.3087C12.1412 0 11.1948 0.946 11.1948 2.114V17.69C11.1948 18.857 12.1412 19.804 13.3087 19.804H28.8848C30.0522 19.804 30.9986 18.857 30.9986 17.69V2.114C30.9986 0.946 30.0522 0 28.8848 0Z" fill="currentColor"/></svg>
      <span class="brand-name">PomoTick</span>
    </div>
    <nav class="sidebar-nav">
      <a class="nav-item" href="/home"><span class="material-symbols-rounded">arrow_back</span><span>Voltar</span></a>
    </nav>
  </div>
  <div class="sidebar-bottom">
    <a class="nav-item" href="/logout"><span class="material-symbols-rounded">logout</span><span>Sair</span></a>
  </div>
</aside>

<main id="appMain">
  <header class="top-bar">
    <div>
      <h1>Painel Admin</h1>
      <p class="greeting-sub">Gerencie usuários da plataforma</p>
    </div>
  </header>

  <section class="panel active" id="panel-admin">
    <div class="panel-head">
      <div><h2>Usuários</h2><span class="panel-sub" id="userCountLabel"></span></div>
      <button class="btn-ghost" id="btnRefreshUsers">
        <span class="material-symbols-rounded">refresh</span> Atualizar
      </button>
    </div>
    <div id="adminMsg" class="msg-box hidden"></div>
    <div id="usersTable" class="users-table"></div>
  </section>
</main>

<div id="editModal" class="overlay hidden">
  <div class="overlay-card small-card">
    <div class="overlay-head">
      <h3>Editar Usuário</h3>
      <button class="icon-btn" id="closeEditModal"><span class="material-symbols-rounded">close</span></button>
    </div>
    <input type="hidden" id="editUserId">
    <div class="form-group"><label>Nome</label><input type="text" id="editName"></div>
    <div class="form-group"><label>Email</label><input type="email" id="editEmail"></div>
    <div class="form-group">
      <label>Role</label>
      <select id="editRole">
        <option value="user">Usuário</option>
        <option value="admin">Admin</option>
      </select>
    </div>
    <button class="btn-main" id="btnConfirmEdit">Salvar</button>
    <div id="editMsg" class="msg-box hidden"></div>
  </div>
</div>

<script>
async function loadUsers() {
  const r    = await fetch('/api/admin/users');
  const data = await r.json();
  if (!data.success) return;
  const label = document.getElementById('userCountLabel');
  const table = document.getElementById('usersTable');
  label.textContent = `${data.users.length} usuário(s) registrado(s)`;

  if (!data.users.length) { table.innerHTML = '<p class="empty-state">Nenhum usuário encontrado.</p>'; return; }

  table.innerHTML = `
    <table>
      <thead><tr><th>Nome</th><th>Email</th><th>Role</th><th>Cadastro</th><th>Ações</th></tr></thead>
      <tbody>
        ${data.users.map(u => `
          <tr>
            <td>${u.name}</td>
            <td>${u.email}</td>
            <td><span class="role-tag ${u.role}">${u.role}</span></td>
            <td>${new Date(u.createdAt).toLocaleDateString('pt-BR')}</td>
            <td class="action-cell">
              <button class="btn-ghost-sm" onclick="openEdit('${u._id}','${u.name}','${u.email}','${u.role}')">Editar</button>
              <button class="btn-danger-sm" onclick="deleteUser('${u._id}')">Excluir</button>
            </td>
          </tr>`).join('')}
      </tbody>
    </table>`;
}

function openEdit(id, name, email, role) {
  document.getElementById('editUserId').value = id;
  document.getElementById('editName').value   = name;
  document.getElementById('editEmail').value  = email;
  document.getElementById('editRole').value   = role;
  document.getElementById('editModal').classList.remove('hidden');
}

document.getElementById('closeEditModal').onclick = () => document.getElementById('editModal').classList.add('hidden');

document.getElementById('btnConfirmEdit').onclick = async () => {
  const id    = document.getElementById('editUserId').value;
  const name  = document.getElementById('editName').value.trim();
  const email = document.getElementById('editEmail').value.trim();
  const role  = document.getElementById('editRole').value;
  const msg   = document.getElementById('editMsg');

  const r    = await fetch(`/api/admin/users/${id}`, { method: 'PUT', headers: {'Content-Type':'application/json'}, body: JSON.stringify({name,email,role}) });
  const data = await r.json();
  msg.textContent = data.success ? 'Salvo!' : (data.error || 'Erro');
  msg.className   = 'msg-box ' + (data.success ? 'success' : 'error');
  if (data.success) { setTimeout(() => { document.getElementById('editModal').classList.add('hidden'); loadUsers(); }, 1000); }
};

async function deleteUser(id) {
  if (!confirm('Excluir este usuário?')) return;
  const r    = await fetch(`/api/admin/users/${id}`, { method: 'DELETE' });
  const data = await r.json();
  const msg  = document.getElementById('adminMsg');
  msg.textContent = data.success ? 'Usuário excluído.' : (data.error || 'Erro');
  msg.className   = 'msg-box ' + (data.success ? 'success' : 'error');
  if (data.success) loadUsers();
}

document.getElementById('btnRefreshUsers').onclick = loadUsers;
loadUsers();
</script>
</body>
</html>
