<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PomoTick</title>
  <link rel="shortcut icon" href="/logo.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;0,400;0,500;1,300&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20,300,0,0" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<audio id="bgMusic" loop><source src="/Sweden.mp3" type="audio/mpeg"></audio>
<audio id="alertSound"><source src="/notificationPomodoro.mp3" type="audio/mpeg"></audio>

<!-- ═══ SIDEBAR ═══════════════════════════════════════════════════════════════ -->
<aside id="sidebar">
  <div class="sidebar-top">
    <div class="brand">
      <svg width="28" height="28" viewBox="0 0 31 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M13.003 20.6648C11.8363 20.6648 10.3338 19.8038 10.3338 18.6371V12.0545H2.20129C1.03028 12.0545 0 12.5582 0 13.7249V29.4388C0 30.6098 1.03028 31.8583 2.20129 31.8583H17.9152C19.0862 31.8583 19.8052 30.6098 19.8052 29.4388V20.6648H13.003Z" fill="currentColor"/>
        <path d="M9.47275 9.2303C9.48688 9.507 9.39122 9.778 9.20659 9.984C9.02196 10.191 8.76329 10.316 8.48687 10.332H0.987254C0.710829 10.316 0.452166 10.191 0.267536 9.984C0.0829064 9.778 -0.0127533 9.507 0.0013679 9.2303V1.10212C-0.0127533 0.826 0.0829064 0.555 0.267536 0.348C0.452166 0.142 0.710829 0.017 0.987254 0H8.48687C8.76329 0.017 9.02196 0.142 9.20659 0.348C9.39122 0.555 9.48688 0.826 9.47275 1.10212V9.2303Z" fill="currentColor"/>
        <path d="M30.9986 30.7562C31.0128 31.033 30.9171 31.304 30.7325 31.51C30.5478 31.717 30.2892 31.842 30.0127 31.858H22.5131C22.2367 31.842 21.978 31.717 21.7934 31.51C21.6088 31.304 21.5131 31.033 21.5272 30.7562V22.628C21.5131 22.351 21.6088 22.08 21.7934 21.874C21.978 21.668 22.2367 21.543 22.5131 21.526H30.0127C30.2892 21.543 30.5478 21.668 30.7325 21.874C30.9171 22.08 31.0128 22.351 30.9986 22.628V30.7562Z" fill="currentColor"/>
        <path d="M28.8848 0H13.3087C12.1412 0 11.1948 0.946 11.1948 2.114V17.69C11.1948 18.857 12.1412 19.804 13.3087 19.804H28.8848C30.0522 19.804 30.9986 18.857 30.9986 17.69V2.114C30.9986 0.946 30.0522 0 28.8848 0Z" fill="currentColor"/>
      </svg>
      <span class="brand-name">PomoTick</span>
    </div>

    <nav class="sidebar-nav">
      <button class="nav-item active" data-panel="todo">
        <span class="material-symbols-rounded">checklist</span>
        <span>Tarefas</span>
      </button>
      <button class="nav-item" data-panel="kanban">
        <span class="material-symbols-rounded">view_kanban</span>
        <span>Kanban</span>
      </button>
      <button class="nav-item" data-panel="pomodoro">
        <span class="material-symbols-rounded">timer</span>
        <span>Pomodoro</span>
      </button>
      <button class="nav-item" data-panel="jam">
        <span class="material-symbols-rounded">groups</span>
        <span>JAM</span>
        <span id="jamBadge" class="badge hidden">●</span>
      </button>
    </nav>
  </div>

  <div class="sidebar-bottom">
    <button class="nav-item" id="btnMusic" title="Música ambiente">
      <span class="material-symbols-rounded" id="musicIcon">music_note</span>
      <span>Música</span>
    </button>
    <button class="nav-item" id="btnProfile" title="Meu perfil">
      <span class="material-symbols-rounded">person</span>
      <span>Perfil</span>
    </button>
    <% if (user.role === 'admin') { %>
    <a class="nav-item" href="/admin">
      <span class="material-symbols-rounded">shield_person</span>
      <span>Admin</span>
    </a>
    <% } %>
    <a class="nav-item" href="/logout">
      <span class="material-symbols-rounded">logout</span>
      <span>Sair</span>
    </a>
  </div>
</aside>

<!-- ═══ MAIN ════════════════════════════════════════════════════════════════ -->
<main id="appMain">

  <!-- greeting bar -->
  <header class="top-bar">
    <div>
      <h1 id="greeting">Bom dia ☀️</h1>
      <p class="greeting-sub">O que você vai estudar hoje?</p>
    </div>
    <div class="top-bar-right">
      <div id="clockDisplay" class="clock"></div>
      <button class="avatar-btn" id="btnProfile2">
        <img id="topAvatar" src="/default-avatar.svg" alt="avatar">
      </button>
    </div>
  </header>

  <!-- ─── TODO PANEL ──────────────────────────────────────────────────────── -->
  <section class="panel active" id="panel-todo">
    <div class="panel-head">
      <div>
        <h2>Lista de Tarefas</h2>
        <span class="panel-sub">Organize o que precisa fazer hoje</span>
      </div>
      <button class="btn-ghost" id="btnOpenReport">
        <span class="material-symbols-rounded">description</span> Relatório
      </button>
    </div>

    <div class="todo-input-row">
      <input id="todoInput" type="text" placeholder="Adicionar tarefa…" maxlength="200">
      <label class="report-toggle" title="Salvar no relatório">
        <input type="checkbox" id="todoInReport">
        <span class="material-symbols-rounded">bookmark</span>
      </label>
      <button class="btn-add" id="btnAddTodo">
        <span class="material-symbols-rounded">add</span>
      </button>
    </div>

    <ul id="todoList" class="todo-list"></ul>
    <p id="todoEmpty" class="empty-state">Nenhuma tarefa ainda. Comece adicionando uma! 🌱</p>
  </section>

  <!-- ─── KANBAN PANEL ────────────────────────────────────────────────────── -->
  <section class="panel" id="panel-kanban">
    <div class="panel-head">
      <div>
        <h2>Kanban</h2>
        <span class="panel-sub">Visualize seu fluxo de trabalho</span>
      </div>
      <button class="btn-ghost" id="btnNewBoard">
        <span class="material-symbols-rounded">add</span> Novo quadro
      </button>
    </div>

    <div id="kanbanBoards" class="kanban-boards-list"></div>
    <p id="kanbanEmpty" class="empty-state">Nenhum quadro ainda. Crie um para começar! 📋</p>

    <!-- board detail overlay -->
    <div id="boardOverlay" class="overlay hidden">
      <div class="overlay-card board-detail">
        <div class="overlay-head">
          <div>
            <h3 id="boardTitle">Quadro</h3>
            <span id="boardDesc" class="panel-sub"></span>
          </div>
          <button class="icon-btn" id="closeBoardOverlay"><span class="material-symbols-rounded">close</span></button>
        </div>
        <div id="boardColumns" class="board-columns"></div>
      </div>
    </div>
  </section>

  <!-- ─── POMODORO PANEL ──────────────────────────────────────────────────── -->
  <section class="panel" id="panel-pomodoro">
    <div class="panel-head">
      <div>
        <h2>Pomodoro</h2>
        <span class="panel-sub" id="pomPhaseLabel">Foco — prepare-se para concentrar</span>
      </div>
    </div>

    <div class="pom-layout">
      <div class="pom-left">
        <div class="timer-ring-wrap">
          <svg class="timer-ring" viewBox="0 0 120 120">
            <circle class="ring-bg" cx="60" cy="60" r="52"/>
            <circle class="ring-progress" id="ringProgress" cx="60" cy="60" r="52"
              stroke-dasharray="326.7" stroke-dashoffset="326.7"/>
          </svg>
          <div class="timer-center">
            <span id="timerDisplay">25:00</span>
            <small id="timerPhaseSmall">foco</small>
          </div>
        </div>

        <div class="pom-controls">
          <button class="btn-pom" id="btnPomStart">
            <span class="material-symbols-rounded" id="pomIcon">play_arrow</span>
          </button>
          <button class="btn-pom-sm" id="btnPomReset" title="Reiniciar">
            <span class="material-symbols-rounded">replay</span>
          </button>
        </div>

        <div class="pom-settings">
          <label>
            <span>Foco (min)</span>
            <input type="number" id="inputPomMin" min="1" max="60" value="25">
          </label>
          <label>
            <span>Pausa (min)</span>
            <input type="number" id="inputRestMin" min="1" max="30" value="5">
          </label>
        </div>
      </div>

      <div class="pom-right">
        <div class="focus-card">
          <h4>Ambiente sonoro</h4>
          <div class="focus-grid">
            <button class="focus-opt" data-env="none">🔇 Silêncio</button>
            <button class="focus-opt active" data-env="lofi">🎵 Música</button>
          </div>
        </div>

        <div class="pom-sessions">
          <h4>Sessões hoje</h4>
          <div id="sessionDots" class="session-dots"></div>
          <p id="sessionCount" class="session-count">0 sessões concluídas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── JAM PANEL ───────────────────────────────────────────────────────── -->
  <section class="panel" id="panel-jam">
    <div class="panel-head">
      <div>
        <h2>JAM Session</h2>
        <span class="panel-sub">Estude junto com outros usuários</span>
      </div>
    </div>

    <div id="jamJoinView" class="jam-join-view">
      <div class="jam-join-card">
        <div class="jam-join-icon">
          <span class="material-symbols-rounded">groups</span>
        </div>
        <h3>Entre ou crie um JAM</h3>
        <p>Compartilhe um código e estude em sincronia com sua equipe usando o mesmo timer Pomodoro.</p>

        <div class="jam-form">
          <input id="jamCodeInput" type="text" placeholder="Código do JAM (ex: STUDY01)" maxlength="10" style="text-transform:uppercase">
          <div class="jam-form-row">
            <div class="form-group">
              <label>Nome do JAM</label>
              <input id="jamNameInput" type="text" placeholder="Meu JAM" maxlength="40">
            </div>
            <div class="form-group">
              <label>Foco (min)</label>
              <input id="jamDurInput" type="number" min="1" max="60" value="25">
            </div>
            <div class="form-group">
              <label>Pausa (min)</label>
              <input id="jamRestInput" type="number" min="1" max="30" value="5">
            </div>
          </div>
          <div class="jam-btns">
            <button class="btn-main" id="btnCreateJam">Criar JAM</button>
            <button class="btn-outline" id="btnJoinJam">Entrar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- active jam view -->
    <div id="jamActiveView" class="jam-active-view hidden">
      <div class="jam-info-bar">
        <div class="jam-code-tag">
          <span class="material-symbols-rounded">tag</span>
          <strong id="activeJamCode">—</strong>
        </div>
        <div class="jam-name-tag" id="activeJamName">—</div>
        <div class="jam-members-count">
          <span class="material-symbols-rounded">group</span>
          <span id="jamMemberCount">0</span> membros
        </div>
        <button class="btn-danger-sm" id="btnLeaveJam">Sair do JAM</button>
      </div>

      <div class="jam-layout">
        <div class="jam-timer-col">
          <div class="timer-ring-wrap">
            <svg class="timer-ring" viewBox="0 0 120 120">
              <circle class="ring-bg" cx="60" cy="60" r="52"/>
              <circle class="ring-progress" id="jamRingProgress" cx="60" cy="60" r="52"
                stroke-dasharray="326.7" stroke-dashoffset="326.7"/>
            </svg>
            <div class="timer-center">
              <span id="jamTimerDisplay">25:00</span>
              <small id="jamPhaseSmall">foco</small>
            </div>
          </div>

          <div class="pom-controls">
            <button class="btn-pom" id="btnJamStart">
              <span class="material-symbols-rounded" id="jamIcon">play_arrow</span>
            </button>
            <button class="btn-pom-sm" id="btnJamStop" title="Parar">
              <span class="material-symbols-rounded">stop</span>
            </button>
          </div>

          <div class="jam-members-list" id="jamMembersList"></div>
        </div>

        <div class="jam-kanban-col">
          <h4>Quadro colaborativo</h4>
          <div id="jamKanban" class="jam-kanban"></div>
        </div>
      </div>
    </div>
  </section>
</main>

<!-- ═══ MODALS ═══════════════════════════════════════════════════════════════ -->

<!-- Profile modal -->
<div id="profileModal" class="overlay hidden">
  <div class="overlay-card profile-card">
    <div class="overlay-head">
      <h3>Meu Perfil</h3>
      <button class="icon-btn" id="closeProfile"><span class="material-symbols-rounded">close</span></button>
    </div>
    <div class="profile-body">
      <div class="avatar-section">
        <div class="avatar-wrap">
          <img id="profileAvatar" src="/default-avatar.svg" alt="avatar">
          <button class="avatar-change-btn" id="btnChangeAvatar" title="Alterar foto">
            <span class="material-symbols-rounded">photo_camera</span>
          </button>
        </div>
        <input type="file" id="avatarInput" accept="image/*" style="display:none">
      </div>
      <div class="profile-fields">
        <div class="form-group">
          <label>Nome</label>
          <input type="text" id="profileName" placeholder="Seu nome" maxlength="60">
        </div>
        <div class="form-group">
          <label>Bio</label>
          <textarea id="profileBio" placeholder="Uma frase sobre você…" maxlength="280" rows="3"></textarea>
        </div>
        <button class="btn-main" id="btnSaveProfile">Salvar alterações</button>
        <div id="profileMsg" class="msg-box hidden"></div>
      </div>
    </div>
  </div>
</div>

<!-- Report modal -->
<div id="reportModal" class="overlay hidden">
  <div class="overlay-card">
    <div class="overlay-head">
      <h3>Relatório de Tarefas</h3>
      <button class="icon-btn" id="closeReport"><span class="material-symbols-rounded">close</span></button>
    </div>
    <div id="reportContent" class="report-content"></div>
  </div>
</div>

<!-- New board modal -->
<div id="boardModal" class="overlay hidden">
  <div class="overlay-card small-card">
    <div class="overlay-head">
      <h3>Novo Quadro Kanban</h3>
      <button class="icon-btn" id="closeBoardModal"><span class="material-symbols-rounded">close</span></button>
    </div>
    <div class="form-group">
      <label>Título</label>
      <input type="text" id="boardTitleInput" placeholder="Nome do quadro" maxlength="80">
    </div>
    <div class="form-group">
      <label>Descrição <small>(opcional)</small></label>
      <input type="text" id="boardDescInput" placeholder="Sobre o que é este quadro?" maxlength="160">
    </div>
    <button class="btn-main" id="btnConfirmNewBoard">Criar quadro</button>
    <div id="boardModalMsg" class="msg-box hidden"></div>
  </div>
</div>

<!-- Add card modal -->
<div id="cardModal" class="overlay hidden">
  <div class="overlay-card small-card">
    <div class="overlay-head">
      <h3>Novo Card</h3>
      <button class="icon-btn" id="closeCardModal"><span class="material-symbols-rounded">close</span></button>
    </div>
    <div class="form-group">
      <label>Título</label>
      <input type="text" id="cardTitleInput" placeholder="O que precisa ser feito?" maxlength="120">
    </div>
    <div class="form-group">
      <label>Descrição</label>
      <textarea id="cardDescInput" placeholder="Detalhes…" maxlength="400" rows="3"></textarea>
    </div>
    <div class="form-group">
      <label>Prioridade</label>
      <select id="cardPriority">
        <option value="low">🟢 Baixa</option>
        <option value="medium" selected>🟡 Média</option>
        <option value="high">🔴 Alta</option>
      </select>
    </div>
    <button class="btn-main" id="btnConfirmCard">Adicionar card</button>
    <div id="cardModalMsg" class="msg-box hidden"></div>
  </div>
</div>

<script src="/app.js"></script>
</body>
</html>
